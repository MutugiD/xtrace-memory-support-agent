# XTrace Memory API
XTRACE_API_KEY=
XTRACE_ORG_ID=
# Used to scope demo memories so reset is safe-ish.
XTRACE_APP_ID=xtrace-memory-support-agent

# Select memory backend:
# - local: persistent SQLite (default; no external keys required)
# - mock: in-memory store (good for quick tests)
# - xtrace: live XTrace API (requires XTRACE_API_KEY + XTRACE_ORG_ID)
MEMORY_BACKEND=local

# Local backend persistence path (SQLite file)
LOCAL_DB_PATH=./data/memory.sqlite

# Legacy alias (treated as MEMORY_BACKEND=mock if set truthy)
XTRACE_MOCK=false

# Optional: used only for generating agent replies.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Server
PORT=3000
