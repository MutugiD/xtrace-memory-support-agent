# XTrace Memory API
XTRACE_API_KEY=
XTRACE_ORG_ID=
# Used to scope demo memories so reset is safe-ish.
XTRACE_APP_ID=xtrace-memory-support-agent
# Optional: run without hitting the live XTrace API (uses in-memory mock store)
XTRACE_MOCK=false

# Optional: used only for generating agent replies.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Server
PORT=3000
