{
  "name": "xtrace-memory-support-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Memory-aware customer support agent demo using XTrace (belief revision, provenance, session continuity).",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx watch src/server.ts",
    "dev:reconciliation": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx watch services/gateway/server.ts",
    "build": "tsc -p tsconfig.json && tsc -p services/tsconfig.json && node scripts/copy-ui.mjs",
    "lint": "eslint .",
    "start": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first node dist/server.js",
    "start:reconciliation": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first node dist-services/gateway/server.js",
    "demo": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx src/demo/run-demo.ts",
    "demo:reconciliation": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx services/demo/run-reconciliation-demo.ts",
    "memory:timeline": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx src/demo/memory-timeline.ts",
    "test": "vitest run",
    "test:baseline": "vitest run src/tests",
    "test:reconciliation": "vitest run services/tests",
    "test:sdk": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx src/tests/sdk-features.ts",
    "test:sdk:reset": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx src/tests/sdk-features.ts --reset"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@fastify/static": "^9.1.3",
    "@xtraceai/memory": "^0.1.0",
    "ai": "^6.0.191",
    "dotenv": "^16.6.1",
    "fastify": "^5.4.0",
    "sql.js": "^1.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.1",
    "@types/sql.js": "^1.4.11",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.4"
  }
}
