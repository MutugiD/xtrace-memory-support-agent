{
  "name": "xtrace-memory-support-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Memory-aware customer support agent demo using XTrace (belief revision, provenance, session continuity).",
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-ui.mjs",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' node dist/server.js",
    "demo": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/demo/run-demo.ts",
    "memory:timeline": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/demo/memory-timeline.ts",
    "test": "vitest run",
    "test:sdk": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/tests/sdk-features.ts",
    "test:sdk:reset": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/tests/sdk-features.ts --reset"
  },
  "dependencies": {
    "@fastify/static": "^8.2.0",
    "@xtraceai/memory": "^0.1.0",
    "ai": "^6.0.191",
    "@ai-sdk/openai": "^3.0.65",
    "dotenv": "^16.6.1",
    "fastify": "^5.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}